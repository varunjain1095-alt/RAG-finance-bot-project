# Copy to `.env` and fill in values. Never commit `.env`.

# Anthropic (Claude generation)
ANTHROPIC_API_KEY=

# Voyage AI (voyage-finance-2 embeddings + rerank-2)
VOYAGE_API_KEY=

# PostgreSQL (match docker-compose defaults)
DATABASE_URL=postgresql://rag:rag@localhost:5433/rag_bot

# Optional: Metabase read-only user (created by db/init/02_metabase_readonly.sql)
# METABASE_DATABASE_URL=postgresql://metabase_readonly:metabase_readonly@localhost:5433/rag_bot

# Optional: Claude model id
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Cheaper eval/smoke runs: claude-haiku-4-5-20251001

# Phase 2 retrieval — placeholder until Phase 5 threshold sweep
# GROUNDING_THRESHOLD=0.35
